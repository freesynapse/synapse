# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  file_string_match_config = debug

else ifeq ($(config),release)
  file_string_match_config = release

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := file-string-match

.PHONY: all clean help $(PROJECTS) 

all: $(PROJECTS)

file-string-match:
ifneq (,$(file_string_match_config))
	@echo "==== Building file-string-match ($(file_string_match_config)) ===="
	@${MAKE} --no-print-directory -C . -f file-string-match.make config=$(file_string_match_config)
endif

clean:
	@${MAKE} --no-print-directory -C . -f file-string-match.make clean

help:
	@echo "Usage: make [config=name] [target]"
	@echo ""
	@echo "CONFIGURATIONS:"
	@echo "  debug"
	@echo "  release"
	@echo ""
	@echo "TARGETS:"
	@echo "   all (default)"
	@echo "   clean"
	@echo "   file-string-match"
	@echo ""
	@echo "For more information, see https://github.com/premake/premake-core/wiki"