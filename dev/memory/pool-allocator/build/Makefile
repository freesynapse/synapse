# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  pool_allocator_config = debug

else ifeq ($(config),release)
  pool_allocator_config = release

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := pool-allocator

.PHONY: all clean help $(PROJECTS) 

all: $(PROJECTS)

pool-allocator:
ifneq (,$(pool_allocator_config))
	@echo "==== Building pool-allocator ($(pool_allocator_config)) ===="
	@${MAKE} --no-print-directory -C . -f pool-allocator.make config=$(pool_allocator_config)
endif

clean:
	@${MAKE} --no-print-directory -C . -f pool-allocator.make clean

help:
	@echo "Usage: make [config=name] [target]"
	@echo ""
	@echo "CONFIGURATIONS:"
	@echo "  debug"
	@echo "  release"
	@echo ""
	@echo "TARGETS:"
	@echo "   all (default)"
	@echo "   clean"
	@echo "   pool-allocator"
	@echo ""
	@echo "For more information, see https://github.com/premake/premake-core/wiki"