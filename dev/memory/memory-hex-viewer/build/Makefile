# Alternative GNU Make workspace makefile autogenerated by Premake

ifndef config
  config=debug
endif

ifndef verbose
  SILENT = @
endif

ifeq ($(config),debug)
  memory_hex_viewer_config = debug

else ifeq ($(config),release)
  memory_hex_viewer_config = release

else
  $(error "invalid configuration $(config)")
endif

PROJECTS := memory-hex-viewer

.PHONY: all clean help $(PROJECTS) 

all: $(PROJECTS)

memory-hex-viewer:
ifneq (,$(memory_hex_viewer_config))
	@echo "==== Building memory-hex-viewer ($(memory_hex_viewer_config)) ===="
	@${MAKE} --no-print-directory -C . -f memory-hex-viewer.make config=$(memory_hex_viewer_config)
endif

clean:
	@${MAKE} --no-print-directory -C . -f memory-hex-viewer.make clean

help:
	@echo "Usage: make [config=name] [target]"
	@echo ""
	@echo "CONFIGURATIONS:"
	@echo "  debug"
	@echo "  release"
	@echo ""
	@echo "TARGETS:"
	@echo "   all (default)"
	@echo "   clean"
	@echo "   memory-hex-viewer"
	@echo ""
	@echo "For more information, see https://github.com/premake/premake-core/wiki"